<table>
  <thead>
    <tr>
      <th>Username</th>
      <th>Email</th>
      <th>Role</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.user_name %></td>
        <td><%= user.email_address %></td>
        <td><%= user.role %></td>
        <td><button>Edit</button><%= link_to "Edit", edit_user_path(user) 
  %></td>
      </tr>
    <% end %>
  </tbody>
</table>
