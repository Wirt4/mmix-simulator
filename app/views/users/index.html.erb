<%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>
<%= tag.div(flash[:notice], style: "color:green") if flash[:notice] %>

<h1>Users</h1>

<table>
  <thead>
    <tr>
      <th>Username</th>
      <th>Email</th>
      <th>Role</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.user_name %></td>
        <td><%= user.email_address %></td>
        <td><%= user.role %></td>
        <td>
          <%= link_to "Edit role", edit_user_path(user) %>
          <% unless user == Current.user %>
            <%= button_to "Delete", user_path(user), method: :delete, data: { confirm: "Delete #{user.user_name}?" } %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
