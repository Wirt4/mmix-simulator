<table>
  <thead>
    <tr>
      <th>Username</th>
      <th>Email</th>
      <th>Role</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.user_name %></td>
        <td><%= user.email_address %></td>
        <td><%= user.role %></td>
        <td><%= button_to "Edit", edit_user_path(user), method: :get, class: "btn--tactile" %></td>
        <td><%= button_to "Delete", user_path(user), method: :delete, class: "btn--tactile" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
