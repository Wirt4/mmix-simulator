<h1>Edit Role: <%= @user.user_name %></h1>

<%= form_with model: @user, url: user_path(@user), method: :patch do |form| %>
  <%= form.select :role, User.roles.keys.map { |r| [r.capitalize, r] }, {}, required: true %><br>
  <%= form.submit "Update role" %>
<% end %>
<br>

<%= link_to "Back to users", users_path %>
