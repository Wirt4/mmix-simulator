<% user = @user || User.new %>
<% if user.errors.any? %>
  <div id="error_explanation">
    <ul>
      <% user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
<%= form_with url: registration_path, model: user do |f| %>
  <div>username</div>
  <%= f.text_field :user_name %>
  <div>email</div>
  <div><%= f.text_field :email_address %></div>
  <div>password</div>
  <div><%= f.password_field :password %></div>
  <div>confirm password</div>
  <div><%= f.password_field :password_confirmation %></div>
  <%= f.submit 'Submit'%>
<% end %>
