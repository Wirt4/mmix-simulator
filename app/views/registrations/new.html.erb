<%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>

<%= form_with model: @user, url: registration_path do |form| %>
  <% @user.errors.full_messages.each do |msg| %>
    <p style="color:red"><%= msg %></p>
  <% end %>

  <%= form.text_field :user_name, required: true, autofocus: true, autocomplete: "username", placeholder: "Username" %><br>
  <%= form.email_field :email_address, required: true, autocomplete: "email", placeholder: "Email address" %><br>
  <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Password", maxlength: 72 %><br>
  <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Confirm password", maxlength: 72 %><br>
  <%= form.submit "Create account" %>
<% end %>
<br>

<%= link_to "Already have an account? Sign in", new_session_path %>
