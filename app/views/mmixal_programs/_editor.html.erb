<%= form_with model: mmixal_program do |form|%>
<div class="ide-layout" data-controller="ide-facade listing-panel">
  <%= form.hidden_field :title %>
  <div class="ide-content">
    <div class="ide-main">
      <div class="panel-header">
        <span class="panel-header-label">Source</span>
        <button type="button" class="listing-toggle" data-action="click->listing-panel#toggle">listing</button>
      </div>
      <div class="editor-container" data-listing-panel-target="panel">
        <div class="editor-body" data-controller="text-format">
          <div class="line-numbers" data-text-format-target="lineNumbers">
            <span>1</span>
          </div>
          <!--below used actions inherited from "editor" parent -->
          <%= form.text_area :source,
            class: "editor-textarea",
            data: {
              ide_facade_target: "textarea",
              text_format_target: "textarea",
              line_numbers_target: "textarea",
              action: "input->text-format#updateLineNumbers scroll->text-format#syncScroll keydown->text-format#handleKeydown"
            },
            spellcheck: false,
            autocomplete: "off",
            autocorrect: "off",
            autocapitalize: "off"
          %>
          <%= render "listing" %>
        </div>
      </div>
      <%= render "output" %>
    </div>
    <%= render "registers" %>
  </div>
  <div class="editor-actions ide-layout-actions">
        <%= button_tag "Assemble", type: "button", class: "btn--tactile", data: {ide_facade_target:"assembleButton", action: "click->ide-facade#assembleUserProgram"} %>
    <%= button_tag "Run", type: "button", class: "btn--tactile btn--tactile--alert", data: {ide_facade_target:"runButton", action: "click->ide-facade#runUserProgram"}%>
    <%= form.submit "Save", class: "btn--tactile", style: "margin-left: auto;" %>
  </div>
</div>
<% end %>
