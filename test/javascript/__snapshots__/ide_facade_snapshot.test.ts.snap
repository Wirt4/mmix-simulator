            <textarea class="editor-textarea" data-ide-facade-target="textarea" spellcheck="false"></textarea>
            <div class="listing-divider"></div>
            <div class="listing-pane">
              <div data-ide-facade-target="listing" class="listing-content"></div>
            </div>
          </div>
        </div>"
`;

exports[`IDE facade UI snapshots > saving code trims trailing newlines 1`] = `
" SETL $255,1
 TRAP 0,Halt,0"
`;

exports[`IDE facade UI snapshots > special registers after connect 1`] = `"<div class="register-row" data-tooltip="arithmetic status register"><span class="register-name">$rA</span><span class="register-hex">0x0000000000000000</span></div><div class="register-row" data-tooltip="bootstrap register (trip)"><span class="register-name">$rB</span><span class="register-hex">0x0000000000000000</span></div><div class="register-row" data-tooltip="continuation register"><span class="register-name">$rC</span><span class="register-hex">0x0000000000000000</span></div><div class="register-row" data-tooltip="dividend register"><span class="register-name">$rD</span><span class="register-hex">0x0000000000000000</span></div><div class="register-row" data-tooltip="epsilon register"><span class="register-name">$rE</span><span class="register-hex">0x0000000000000000</span></div><div class="register-row" data-tooltip="failure location register"><span class="register-name">$rF</span><span class="register-hex">0x0000000000000000</span></div><div class="register-row" data-tooltip="global threshold register"><span class="register-name">$rG</span><span class="register-hex">0x0000000000000000</span></div><div class="register-row" data-tooltip="himult register"><span class="register-name">$rH</span><span class="register-hex">0x0000000000000000</span></div><div class="register-row" data-tooltip="interval counter"><span class="register-name">$rI</span><span class="register-hex">0x0000000000000000</span></div><div class="register-row" data-tooltip="return-jump register"><span class="register-name">$rJ</span><span class="register-hex">0x0000000000000000</span></div><div class="register-row" data-tooltip="interrupt mask register"><span class="register-name">$rK</span><span class="register-hex">0x0000000000000000</span></div><div class="register-row" data-tooltip="local threshold register"><span class="register-name">$rL</span><span class="register-hex">0x0000000000000000</span></div><div class="regi